# Copy this file to .env and fill in what you have.
# Anything left blank simply falls back to sample data for that source —
# the server runs fine with zero, some, or all of these configured.

PORT=3000

# ─── Anthropic (AI executive narrative) ─────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Jira Cloud ──────────────────────────────────────────────────────
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SENS

# ─── GitLab ──────────────────────────────────────────────────────────
# Personal Access Token (scope: read_api):
# https://docs.gitlab.com/ee/user/profile/personal_access_tokens.html
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=

# ─── Build system (GitHub Actions by default) ───────────────────────
# Fine-grained PAT with Actions:read on the target repo:
# https://github.com/settings/tokens
BUILD_PROVIDER=github
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
